            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login succeeded', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.tokens) {",
                  "  pm.environment.set('customerAccessToken', json.tokens.accessToken);",
                  "  pm.environment.set('customerRefreshToken', json.tokens.refreshToken);",
                  "}"
                ]
