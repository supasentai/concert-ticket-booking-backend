  "info": {
    "_postman_id": "4f2a083e-d1b8-4c55-918c-b8f7f8f98ec6",
    "name": "Concert Ticket Booking API",
    "description": "Local Postman collection for the NestJS Concert Ticket Booking backend. Recommended order: run Health, login as customer/operator, fetch or create a concert, create a ticket category when needed, then exercise bookings, vouchers, dashboard, and operator booking monitoring. Import the matching Local environment and update operator credentials from your own .env file.",
